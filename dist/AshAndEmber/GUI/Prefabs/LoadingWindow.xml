<!--
  Ash and Ember — overrides the engine's loading screen with a black title card.
  Same prefab name as Native's LoadingWindow, and this module loads after Native,
  so this wins. Fully static (no data bindings) so it renders regardless of the
  loading view model. Uses the mod's existing gold brushes (GUI/Brushes/AshEmber.xml).
-->
<Prefab>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#000000FF" DoNotUseCustomScale="true">
      <Children>
        <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Center" StackLayout.LayoutMethod="VerticalTopToBottom">
          <Children>
            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" Brush="AshEmber.Splash.Title" Text="ASH &amp; EMBER" />
            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" Brush="AshEmber.Splash.Subtitle" Text="Kindle the Inner Fire" MarginTop="20" />
          </Children>
        </ListPanel>
      </Children>
    </Widget>
  </Window>
</Prefab>
