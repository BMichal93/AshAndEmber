    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>

    <!--
      ----------------------------------------------------------------
      Set BannerlordPath to your Bannerlord root directory and BannerlordBin
      to the DLL subfolder for your platform. Both can be environment
      variables (recommended) or edited directly here as fallback values.

      Steam (default):
        BannerlordPath = C:\Program Files (x86)\Steam\steamapps\common\Mount & Blade II Bannerlord
        BannerlordBin  = Win64_Shipping_Client

      Xbox / Game Pass:
        BannerlordPath = C:\XboxGames\Mount & Blade II- Bannerlord\Content
        BannerlordBin  = Gaming.Desktop.x64_Shipping_Client

      PowerShell example:
        $env:BannerlordPath = "C:\Program Files (x86)\Steam\steamapps\common\Mount & Blade II Bannerlord"
        $env:BannerlordBin  = "Win64_Shipping_Client"
        dotnet build TheWitheringArt.csproj
      ----------------------------------------------------------------
    -->
    <BannerlordPath Condition="'$(BannerlordPath)' == ''">C:\Program Files (x86)\Steam\steamapps\common\Mount &amp; Blade II Bannerlord</BannerlordPath>
    <BannerlordBin  Condition="'$(BannerlordBin)'  == ''">Win64_Shipping_Client</BannerlordBin>
    <_BL>$(BannerlordPath)\bin\$(BannerlordBin)</_BL>
  </PropertyGroup>

